# ACDS backend local development environment
# Do not commit real secrets. Replace these values in backend/.env.

# Development-only example secret. Use a unique long random value locally.
JWT_SECRET_KEY=replace-with-a-long-random-local-development-secret

# Development-only admin account. Use a strong local password, not this example.
ADMIN_EMAIL=admin@acds.com
ADMIN_PASSWORD=DevOnly-Replace-With-A-Strong-Local-Password-2026!
