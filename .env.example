# =============================================================================
# ACDS - Autonomous Cyber Defense System
# Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed

# Environment
ENV=development
LOG_LEVEL=INFO

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
# MongoDB connection string
MONGO_URI=mongodb://localhost:27017
# For Docker: MONGO_URI=mongodb://acds:acds123@mongo:27017/acds?authSource=admin

# Database name
DB_NAME=acds

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret key (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=acds-secret-key-change-in-production-2024

# =============================================================================
# MODEL SETTINGS
# =============================================================================
# Path to trained model
MODEL_PATH=ml/models/phishing_model.pkl
MODEL_INFO_PATH=ml/models/model_info.json

# =============================================================================
# NOTIFICATION SETTINGS (Optional)
# =============================================================================
# SMTP settings for email notifications
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@acds.com

# Webhook URL for Slack/Teams notifications
WEBHOOK_URL=

# =============================================================================
# STORAGE SETTINGS
# =============================================================================
# Quarantine folder for isolated emails
QUARANTINE_FOLDER=data/quarantine

# Blocked senders list
BLOCKED_SENDERS_FILE=data/blocked_senders.json

# Incidents database (JSON)
INCIDENTS_DB_PATH=data/incidents.json

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================
# API base URL for frontend (used by Vite)
# VITE_API_URL=http://127.0.0.1:8010/api/v1
